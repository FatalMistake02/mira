{
  "name": "mira-android",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android",
    "android:build": "cd android && ./gradlew assembleRelease",
    "android:build:debug": "cd android && ./gradlew assembleDebug",
    "android:clean": "cd android && ./gradlew clean",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "typecheck": "tsc"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-native": "^0.75.0",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native-stack": "^6.9.26",
    "react-native-screens": "^3.31.1",
    "react-native-safe-area-context": "^4.10.5",
    "react-native-gesture-handler": "^2.14.5",
    "react-native-web-view": "^13.8.5",
    "react-native-async-storage": "@react-native-async-storage/async-storage@^1.23.1",
    "react-native-vector-icons": "^10.1.0",
    "axios": "^1.6.2",
    "zustand": "^4.4.1"
  },
  "devDependencies": {
    "@babel/core": "^7.23.5",
    "@babel/preset-env": "^7.23.5",
    "@babel/preset-react": "^7.23.3",
    "@babel/preset-typescript": "^7.23.3",
    "@react-native/babel-preset": "^0.75.0",
    "@react-native/eslint-config": "^0.75.0",
    "@react-native/typescript-config": "^0.75.0",
    "@types/react": "^18.2.37",
    "@types/react-native": "0.75.0",
    "@typescript-eslint/eslint-plugin": "^6.11.0",
    "@typescript-eslint/parser": "^6.11.0",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.0",
    "eslint": "^8.52.0",
    "jest": "^29.7.0",
    "metro-react-native-babel-preset": "^0.77.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.3"
  }
